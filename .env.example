# ============================================
# UlasTekno Auto-Blog Environment Variables
# ============================================
# Copy file ini ke .env (tanpa .example) dan isi semua value
# File .env sudah di-ignore Git, jadi aman untuk token

# --------------------------------------------------
# WAJIB: GitHub Personal Access Token
# --------------------------------------------------
# Token untuk otomasi push ke repo GitHub Pages
# Cara buat: GitHub Settings > Developer settings > Personal access tokens > Tokens (classic)
# Scope yang dibutuhkan: repo (full control of private repositories)
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --------------------------------------------------
# OPSIONAL: Telegram Bot Token (untuk notifikasi)
# --------------------------------------------------
# Kalau mau dapat notifikasi ke Telegram setiap ada artikel baru
# Cara buat: Buka @BotFather di Telegram → /newbot → copy token
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Chat ID Telegram untuk menerima notifikasi
# Biasanya ID user Telegram (bukan username)
# Kalau dikosongkan, default ke 1785346764
TELEGRAM_CHAT_ID=1785346764

# --------------------------------------------------
# OPSIONAL: Shopee Affiliate (untuk link monetisasi)
# --------------------------------------------------
# Kalau punya Shopee Affiliate API, bisa tambahkan di sini
# SHOPEE_AFFILIATE_ID=your_affiliate_id
# SHOPEE_APP_KEY=your_app_key
# SHOPEE_SECRET=your_secret

# --------------------------------------------------
# OPSIONAL: Unsplash API (untuk banner image)
# --------------------------------------------------
# Script banner sudah include access key default
# Tapi kalau limit habis, bisa ganti dengan key sendiri
# UNSPLASH_ACCESS_KEY=your_unsplash_access_key
